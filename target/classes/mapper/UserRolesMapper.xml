<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yjb.business.app.dao.UserRolesMapper">
	<resultMap id="BaseResultMap" type="com.yjb.business.app.entity.UserRolesEntity">
		<id column="user_id" jdbcType="BIGINT" property="userId" />
		<id column="role_id" jdbcType="BIGINT" property="roleId" />
	</resultMap>
	<insert id="insertUserRoles">
		insert into user_roles(user_id, role_id) values(#{userRolesDto.userId}, #{userRolesDto.roleId})
	</insert>
</mapper>